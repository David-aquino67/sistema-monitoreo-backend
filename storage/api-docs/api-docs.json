{
    "openapi": "3.0.0",
    "info": {
        "title": "MOCACI API",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "/",
            "description": "API Server"
        }
    ],
    "paths": {
        "/api/auth/login": {
            "post": {
                "tags": [
                    "Auth"
                ],
                "summary": "Migrar sesión del SIBOP al MOCACI",
                "description": "Endpoint para autenticar usuarios migrando su sesión (token) desde el SIBOP. Cada que se crea un token nuevo para el MOCACI se invalida el anterior.",
                "operationId": "a36cee381b33e2f2a92aaeddd3ad1a34",
                "responses": {
                    "200": {
                        "description": "Autenticación exitosa",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "token": {
                                            "description": "Token de autenticación generado para MOCACI",
                                            "type": "string",
                                            "example": "1|abcdefghijklmnopqrstuvwxyz1234567890"
                                        },
                                        "permiso": {
                                            "description": "ID del permiso asociado al usuario",
                                            "type": "string",
                                            "example": "admin"
                                        },
                                        "id_sibop": {
                                            "description": "ID del usuario en SIBOP",
                                            "type": "integer",
                                            "example": 123
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Usuario no encontrado",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "title": {
                                            "type": "string",
                                            "example": "Error de autenticación"
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Usuario no encontrado"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Token no proporcionado",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Token no proporcionado"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Token de proporcionado, pero invalido en el SIBOP",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "error": {
                                            "type": "string",
                                            "example": "Token inválido o expirado"
                                        },
                                        "exception": {
                                            "type": "string",
                                            "example": "Unauthenticated SIBOP token"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/auth/logout": {
            "get": {
                "tags": [
                    "Auth"
                ],
                "summary": "Cerrar sesión del usuario (i.e. eliminar tokens)",
                "description": "Endpoint para cerrar la sesión del usuario autenticado, es decir, eliminar la validez de su ultimo token creado",
                "operationId": "f5095a7041d9e3247d073c1f468efce2",
                "responses": {
                    "204": {
                        "description": "Sesión cerrada exitosamente (Sin contenido)",
                        "content": {
                            "application/json": {
                                "schema": {}
                            }
                        }
                    },
                    "401": {
                        "description": "No autenticado - Token inválido, expirado o no proporcionado",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Unauthenticated."
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/auth/validate/token": {
            "get": {
                "tags": [
                    "Auth"
                ],
                "summary": "Validar token de sesión actual",
                "description": "Endpoint para verificar que el token del usuario actual sigue siendo válido en el SIBOP.",
                "operationId": "04a2e6c6f915cdda4f08b07c83ce99b0",
                "responses": {
                    "200": {
                        "description": "Token válido",
                        "content": {
                            "application/json": {
                                "schema": {}
                            }
                        }
                    },
                    "401": {
                        "description": "No autenticado - Token inválido, expirado o no proporcionado",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Unauthenticated."
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/auth/validate/user/{id_usuario}": {
            "get": {
                "tags": [
                    "Auth"
                ],
                "summary": "Verificar existencia de usuario",
                "description": "Endpoint para verificar si un usuario existe en el sistema mediante su ID de SIBOP.",
                "operationId": "44533ba8b96f96e8ecb85cae021c83bb",
                "parameters": [
                    {
                        "name": "id_usuario",
                        "in": "path",
                        "description": "ID del usuario en SIBOP",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "example": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Verificación exitosa",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "existe": {
                                            "description": "Indica si el usuario existe en el sistema",
                                            "type": "boolean",
                                            "example": true
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
