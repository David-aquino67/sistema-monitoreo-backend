            "post": {
                "tags": [
                    "Usuarios"
                ],
                "summary": "Importa un usuario desde SIBOP al sistema MOCACI",
                "description": "Endpoint para registrar/importar un usuario del SIBOP al sistema MOCACI con un permiso específico",
                "operationId": "6d7ce1e8942aa8b0779e411a1c35f826",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "id_sibop",
                                    "FK_permiso_ability",
                                    "id_sibop_jefe"
                                ],
                                "properties": {
                                    "id_sibop": {
                                        "description": "ID del usuario en SIBOP",
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "FK_permiso_ability": {
                                        "description": "Permiso a asignar al usuario",
                                        "type": "string",
                                        "example": "admin"
                                    },
                                    "id_sibop_jefe": {
                                        "description": "ID del jefe del usuario en SIBOP",
                                        "type": "integer",
                                        "example": 1
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Usuario importado exitosamente",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "id_sibop": {
                                            "type": "integer",
                                            "example": 1
                                        },
                                        "FK_permiso_ability": {
                                            "type": "string",
                                            "example": "admin"
                                        },
                                        "REGISTRO_fecha_creacion": {
                                            "type": "string",
                                            "format": "date-time",
                                            "example": "2026-01-22T17:09:12.176000Z"
                                        },
                                        "REGISTRO_fecha_ultimo_cambio": {
                                            "type": "string",
                                            "format": "date-time",
                                            "example": "2026-01-22T17:09:12.176000Z"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "No autorizado",
                        "content": {
                            "application/json": {
                                "schema": {}
                            }
                        }
                    },
                    "422": {
                        "description": "Usuario registrado previamente",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "Usuario registrado previamente"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
