                                    "type": "array",
                                    "items": {
                                        "properties": {
                                            "numero_version": {
                                                "type": "string",
                                                "example": "1.0.0"
                                            },
                                            "fecha_liberacion": {
                                                "type": "string",
                                                "format": "date",
                                                "example": "2026-01-27"
                                            },
                                            "created_at": {
                                                "type": "string",
                                                "format": "date-time",
                                                "example": "2026-01-27T12:00:00.000000Z"
                                            },
                                            "updated_at": {
                                                "type": "string",
                                                "format": "date-time",
                                                "example": "2026-01-27T12:00:00.000000Z"
                                            }
                                        },
                                        "type": "object"
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "No autorizado",
                        "content": {
                            "application/json": {
                                "schema": {}
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
